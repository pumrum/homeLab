# /etc/caddy/caddy.env
# Changes to this file must be committed with a full process restart
# Permissions: chmod 600 /etc/caddy/caddy.env
#              chown caddy:caddy /etc/caddy/caddy.env
# Referenced via EnvironmentFile=/etc/caddy/caddy.env in the systemd drop-in.
# No quotes, no export keyword, no [Service] wrapper — just KEY=value pairs.

# -----------------------------------------------------------------------------
# Dynu DNS API
# -----------------------------------------------------------------------------
DYNU_API_TOKEN=your_dynu_api_token_here

# -----------------------------------------------------------------------------
# Base domain (all sites live under this)
# -----------------------------------------------------------------------------
OWN_DYNU_DOMAIN=your_domain.com

# -----------------------------------------------------------------------------
# Let's Encrypt account email
# -----------------------------------------------------------------------------
ACME_EMAIL=youremail@yourdomain.com

# -----------------------------------------------------------------------------
# Backend IPs
# -----------------------------------------------------------------------------
IP_SERVICE1=192.168.1.1
IP_SERVICE2=192.168.1.2
IP_SERVICE3=192.168.1.3
IP_WEBAPP=127.0.0.1

# -----------------------------------------------------------------------------
# Backend ports (optional — fine to leave in Caddyfile, but here for portability)
# -----------------------------------------------------------------------------
PORT_SERVICE1=1111
PORT_SERVICE1=2222
PORT_SERVICE1=3333
PORT_WEBAPP=8080

# -----------------------------------------------------------------------------
# Network access control
# -----------------------------------------------------------------------------
LAN_SUBNET=192.168.0.0/16

# -----------------------------------------------------------------------------
# mTLS
# -----------------------------------------------------------------------------
MTLS_CA_PATH=/etc/caddy/ca.crt
